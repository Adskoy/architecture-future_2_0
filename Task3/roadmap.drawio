        <mxCell id="50" value="Интеграция в новое хранилище данных" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="-870" width="420" height="60" as="geometry" />
